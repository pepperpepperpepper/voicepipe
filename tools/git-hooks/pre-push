#!/usr/bin/env bash
set -euo pipefail

# Pre-push hook: on EVERY push, build the release APK and publish it to the
# F-Droid repo (blocking — the push aborts if the publish fails). versionCode
# is the git commit count, so no manual version bumps are needed. Models
# ~/wtf-notifier/tools/git-hooks/pre-push.
#
# Activate once per clone:
#   git config core.hooksPath tools/git-hooks
#
# Bypass a single push:
#   VOICEPIPE_SKIP_RELEASE=1 git push

repo_root="$(git rev-parse --show-toplevel)"
remote="${1:-origin}"
zero="0000000000000000000000000000000000000000"
ranges=()

# Build the union of commit ranges about to be pushed (stdin: <lref> <loid> <rref> <roid>).
while read -r local_ref local_oid remote_ref remote_oid; do
  [[ -z "$local_oid" || "$local_oid" == "$zero" ]] && continue   # ref deletion
  if [[ -z "$remote_oid" || "$remote_oid" == "$zero" ]]; then
    base="$(git -C "$repo_root" merge-base "$local_oid" "${remote}/HEAD" 2>/dev/null || true)"
    [[ -n "$base" ]] && ranges+=("${base}..${local_oid}") || ranges+=("${local_oid}")
  else
    ranges+=("${remote_oid}..${local_oid}")
  fi
done

[[ "${#ranges[@]}" -eq 0 ]] && exit 0   # nothing being pushed (e.g. ref deletion)

if [[ -n "${VOICEPIPE_SKIP_RELEASE:-}" ]]; then
  echo "==> pre-push: F-Droid publish skipped (VOICEPIPE_SKIP_RELEASE=1)"
  exit 0
fi

# Publish on EVERY push. versionCode = git commit count, so each push with new
# commits yields a fresh version; release-android.sh skips gracefully when the
# current versionCode is already published (re-push with no new commits = no-op).
echo "==> pre-push: building + publishing release APK to F-Droid"
echo "    (set VOICEPIPE_SKIP_RELEASE=1 to bypass)"
"$repo_root/tools/release-android.sh"

exit 0
